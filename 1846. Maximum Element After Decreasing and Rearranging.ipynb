    "def maximumElementAfterDecrementingAndRearranging(arr):\n",
    "    arr.sort()\n",
    "    n = len(arr)\n",
    "    _min = 0\n",
    "    for value in arr:\n",
    "        if value>_min:\n",
    "            _min+=1\n",
    "    return _min"
