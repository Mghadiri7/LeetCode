   "source": [
    "def bitwiseComplement(n):\n",
    "    if n==0:\n",
    "        return 1\n",
    "    k = 0\n",
    "    while n >= 2**k:\n",
    "        k+=1\n",
    "    return (2**k)-n-1"
   ]
  },
