   "source": [
    "def checkOnesSegment(s):\n",
    "    flag = True\n",
    "    for x in s:\n",
    "        if x == '0':\n",
    "            flag = False\n",
    "        elif x == '1' and flag == False:\n",
    "            return False\n",
    "    return True"
   ]
