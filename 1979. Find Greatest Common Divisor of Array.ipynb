   "source": [
    "def findGCD(nums):\n",
    "    _min = min(nums)\n",
    "    _max = max(nums)\n",
    "    res = 1\n",
    "    for i in range(2, _min+1):\n",
    "        if _min % i == 0 and _max % i == 0:\n",
    "            res = i\n",
    "    return res"
   ]
  },
