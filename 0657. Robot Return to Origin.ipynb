   "source": [
    "from collections import Counter\n",
    "\n",
    "def judgeCircle(moves):\n",
    "    _dict = Counter(moves)\n",
    "    if _dict['L']==_dict['R'] and _dict['U']==_dict['D']:\n",
    "        return True\n",
    "    return False"
   ]
  },
