   "source": [
    "def minimumCost(cost):\n",
    "    cost.sort(reverse = True)\n",
    "    n = len(cost)\n",
    "    ans = 0\n",
    "\n",
    "    for i in range(n):\n",
    "        if i%3==2:\n",
    "            continue\n",
    "        ans += cost[i]\n",
    "\n",
    "    return ans"
   ]
  },
