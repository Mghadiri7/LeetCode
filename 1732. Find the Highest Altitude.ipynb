   "source": [
    "def largestAltitude(gain):\n",
    "    n = len(gain)\n",
    "    for i in range(1, n):\n",
    "        gain[i] = gain[i] + gain[i-1]\n",
    "    res = max(gain)\n",
    "    return res if res>0 else 0"
   ]
  },
